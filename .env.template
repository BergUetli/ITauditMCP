# =============================================================
# IT Audit MCP Server - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
# NEVER commit .env to git (it's in .gitignore)
# =============================================================

# --- Supabase (Database) ---
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://inhioznyfkjcvjjepdxq.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Anthropic (Claude) ---
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# Which Claude model to use. Options:
#   claude-sonnet-4-20250514  (good balance of speed/quality)
#   claude-opus-4-0-20250514  (best quality, slower)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI (Optional - for reviewer LLM or Azure) ---
# Standard OpenAI:
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o

# Azure OpenAI (for bank/enterprise deployments):
# Set OPENAI_API_TYPE=azure to switch to Azure mode
# OPENAI_API_TYPE=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# --- MCP Server ---
# Transport: "streamable-http" for remote, "stdio" for local/Claude Desktop
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- Quality Layer ---
# Minimum confidence score to include in results (0.0 to 1.0)
MIN_CONFIDENCE_THRESHOLD=0.5

# --- Learning Loop ---
# Whether corrections require your manual approval before applying
REQUIRE_HUMAN_REVIEW=true
